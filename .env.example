# Copy to .env and fill in your key from https://massive.com/dashboard/keys
# (Massive is the new name for Polygon.io)
MASSIVE_API_KEY=your_massive_api_key_here

# Postgres connection string (e.g. from https://neon.tech). If unset, the app
# falls back to a local SQLite file: create it with `sqlite3 finance.db < schema.sql`
DATABASE_URL=
